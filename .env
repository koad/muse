# AI Session Settings
KOAD_IO_QUIET=1

# Git Configuration
GIT_AUTHOR_NAME=Muse
GIT_AUTHOR_EMAIL=muse@kingofalldata.com
GIT_COMMITTER_NAME=Muse
GIT_COMMITTER_EMAIL=muse@kingofalldata.com

# Hook routing
