# auto generated by koad:io entity gestate script
KOAD_IO_BIND_IP=127.0.0.1
METEOR_PACKAGE_DIRS=/home/koad/.koad-io/packages

# Muse Identity
ENTITY=muse
ENTITY_DIR=/home/koad/.muse
ENTITY_HOME=/home/koad/.muse/home/muse

# My Public Keys
ENTITY_KEYS=/home/koad/.muse/muse.keys

# Trust Chain
TRUST_CHAIN=/home/koad/.muse/trust

# Creator
CREATOR=koad
CREATOR_KEYS=canon.koad.sh/koad.keys

# Mother
MOTHER=juno
MOTHER_KEYS=canon.koad.sh/juno.keys

# Purpose
ROLE=visual-designer
